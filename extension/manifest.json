{
  "manifest_version": 2,
  "name": "Lockbox",
  "version": "1.0.0",
  "description": "Auto-fill passwords from your self-hosted Lockbox vault",
  "permissions": ["activeTab", "storage", "*://*/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "lockbox@mhamida292"
    }
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
